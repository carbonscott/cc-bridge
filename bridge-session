#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""cc-bridge session manager: holds a persistent SSH connection and
exposes a Unix domain socket for local CLI access.

Usage:
    bridge-session start --name myproject -- ssh host 'bridge-server --root-dir /path'
    bridge-session stop myproject
    bridge-session status myproject
    bridge-session list
"""

import argparse
import json
import os
import signal
import socket
import sys
import subprocess
import threading
import time
from pathlib import Path

DEFAULT_DIR = Path.home() / ".bridge"
DEFAULT_NAME = "default"


def _session_dir(name: str) -> Path:
    return DEFAULT_DIR / name


def _session_paths(name: str) -> tuple[Path, Path, Path]:
    """Return (socket_path, pid_path, log_path) for a named session."""
    d = _session_dir(name)
    return d / "session.sock", d / "session.pid", d / "session.log"


def _is_pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True  # Process exists but owned by another user


def _validate_session_name(name: str):
    if "/" in name or name.startswith("."):
        print(f"Error: Invalid session name '{name}'. Must not contain '/' or start with '.'", file=sys.stderr)
        sys.exit(1)


def start_session(ssh_cmd: list[str], name: str, foreground: bool):
    _validate_session_name(name)
    sock_path, pid_path, log_path = _session_paths(name)
    sock_path.parent.mkdir(parents=True, exist_ok=True)

    # Refuse to overwrite a live session
    if pid_path.exists():
        pid = int(pid_path.read_text().strip())
        if _is_pid_alive(pid):
            print(f"Error: Session '{name}' is already running (pid {pid}).", file=sys.stderr)
            print(f"Stop it first: bridge-session stop {name}", file=sys.stderr)
            sys.exit(1)
        # Stale session — clean up
        sock_path.unlink(missing_ok=True)
        pid_path.unlink(missing_ok=True)

    # Clean up stale socket (no PID file but socket lingers)
    if sock_path.exists():
        sock_path.unlink()

    if not foreground:
        # Daemonize
        pid = os.fork()
        if pid > 0:
            print(f"Session '{name}' started (pid {pid}), socket: {sock_path}")
            sys.exit(0)
        os.setsid()
        # Redirect stdio
        devnull = os.open(os.devnull, os.O_RDWR)
        os.dup2(devnull, 0)
        log_fd = os.open(str(log_path), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
        os.dup2(log_fd, 1)
        os.dup2(log_fd, 2)

    # Write PID file
    pid_path.write_text(str(os.getpid()))

    # Spawn SSH + bridge-server
    proc = subprocess.Popen(
        ssh_cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )

    lock = threading.Lock()
    server_alive = True

    def handle_client(conn: socket.socket):
        nonlocal server_alive
        try:
            # Read one JSON line from client
            data = b""
            while True:
                chunk = conn.recv(4096)
                if not chunk:
                    return
                data += chunk
                if b"\n" in data:
                    break

            request_line = data.split(b"\n", 1)[0] + b"\n"

            with lock:
                if not server_alive:
                    error = json.dumps({"id": "?", "ok": False, "error": "Server process is dead"}) + "\n"
                    conn.sendall(error.encode())
                    return

                try:
                    proc.stdin.write(request_line)
                    proc.stdin.flush()
                except BrokenPipeError:
                    server_alive = False
                    error = json.dumps({"id": "?", "ok": False, "error": "Server process died (broken pipe)"}) + "\n"
                    conn.sendall(error.encode())
                    return

                # Read one JSON line response
                response_line = proc.stdout.readline()
                if not response_line:
                    server_alive = False
                    error = json.dumps({"id": "?", "ok": False, "error": "Server process died (EOF)"}) + "\n"
                    conn.sendall(error.encode())
                    return

            conn.sendall(response_line)
        except Exception as e:
            try:
                error = json.dumps({"id": "?", "ok": False, "error": f"Session error: {e}"}) + "\n"
                conn.sendall(error.encode())
            except Exception:
                pass
        finally:
            conn.close()

    # Create Unix domain socket
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(str(sock_path))
    srv.listen(5)
    srv.settimeout(1.0)  # Allow periodic check of process health

    def cleanup(*_args):
        srv.close()
        proc.terminate()
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            proc.kill()
        sock_path.unlink(missing_ok=True)
        pid_path.unlink(missing_ok=True)
        # Remove session directory if empty
        try:
            _session_dir(name).rmdir()
        except OSError:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGINT, cleanup)

    if foreground:
        print(f"Session '{name}' running (pid {os.getpid()}), socket: {sock_path}")
        print(f"SSH command: {' '.join(ssh_cmd)}")
        print("Press Ctrl-C to stop.")

    try:
        while True:
            # Check if SSH process is still alive
            if proc.poll() is not None:
                stderr_out = proc.stderr.read().decode(errors="replace") if proc.stderr else ""
                msg = f"SSH process exited with code {proc.returncode}"
                if stderr_out.strip():
                    msg += f": {stderr_out.strip()}"
                print(msg, file=sys.stderr)
                break

            try:
                conn, _ = srv.accept()
                t = threading.Thread(target=handle_client, args=(conn,), daemon=True)
                t.start()
            except socket.timeout:
                continue
    finally:
        cleanup()


def stop_session(name: str):
    _validate_session_name(name)
    sock_path, pid_path, _ = _session_paths(name)
    if not pid_path.exists():
        print(f"No active session '{name}' found.")
        sys.exit(1)

    pid = int(pid_path.read_text().strip())
    if _is_pid_alive(pid):
        os.kill(pid, signal.SIGTERM)
        # Wait for the daemon to clean up
        for _ in range(20):
            if not _is_pid_alive(pid):
                break
            time.sleep(0.25)
        print(f"Session '{name}' (pid {pid}) stopped.")
    else:
        print(f"Session '{name}' (pid {pid}) was not running. Cleaning up.")
        sock_path.unlink(missing_ok=True)
        pid_path.unlink(missing_ok=True)
        try:
            _session_dir(name).rmdir()
        except OSError:
            pass


def session_status(name: str):
    _validate_session_name(name)
    sock_path, pid_path, _ = _session_paths(name)
    if not pid_path.exists():
        print(f"No active session '{name}'.")
        sys.exit(1)

    pid = int(pid_path.read_text().strip())
    if _is_pid_alive(pid):
        print(f"Session '{name}' running (pid {pid}), socket: {sock_path}")
    else:
        print(f"Session '{name}' (pid {pid}) is dead. Cleaning up.")
        sock_path.unlink(missing_ok=True)
        pid_path.unlink(missing_ok=True)
        try:
            _session_dir(name).rmdir()
        except OSError:
            pass
        sys.exit(1)


def list_sessions():
    if not DEFAULT_DIR.is_dir():
        print("No sessions.")
        return

    found = False
    for d in sorted(DEFAULT_DIR.iterdir()):
        pid_path = d / "session.pid"
        if not d.is_dir() or not pid_path.exists():
            continue
        name = d.name
        pid = int(pid_path.read_text().strip())
        alive = _is_pid_alive(pid)
        status = "running" if alive else "dead"
        sock_path = d / "session.sock"
        print(f"{name}\tpid={pid}\t{status}\t{sock_path}")
        found = True

    if not found:
        print("No sessions.")


def main():
    parser = argparse.ArgumentParser(description="cc-bridge session manager")
    sub = parser.add_subparsers(dest="action", required=True)

    p_start = sub.add_parser("start", help="Start a bridge session")
    p_start.add_argument("--name", default=DEFAULT_NAME, help="Session name (default: 'default')")
    p_start.add_argument("--foreground", action="store_true", help="Run in foreground (don't daemonize)")
    p_start.add_argument("cmd", nargs=argparse.REMAINDER, help="SSH command (after --)")

    p_stop = sub.add_parser("stop", help="Stop a bridge session")
    p_stop.add_argument("name", nargs="?", default=DEFAULT_NAME, help="Session name (default: 'default')")

    p_status = sub.add_parser("status", help="Check session status")
    p_status.add_argument("name", nargs="?", default=DEFAULT_NAME, help="Session name (default: 'default')")

    sub.add_parser("list", help="List all sessions")

    args = parser.parse_args()

    if args.action == "start":
        cmd = args.cmd
        # Strip leading '--' if present
        if cmd and cmd[0] == "--":
            cmd = cmd[1:]
        if not cmd:
            print("Error: No SSH command provided. Usage: bridge-session start -- ssh host 'command'", file=sys.stderr)
            sys.exit(1)
        start_session(cmd, args.name, args.foreground)
    elif args.action == "stop":
        stop_session(args.name)
    elif args.action == "status":
        session_status(args.name)
    elif args.action == "list":
        list_sessions()


if __name__ == "__main__":
    main()
