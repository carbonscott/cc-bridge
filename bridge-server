#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# ///
"""cc-bridge server: JSON-over-stdio remote filesystem bridge.

Reads NDJSON requests from stdin, executes filesystem/shell operations,
writes NDJSON responses to stdout. Designed to run on a remote host
behind an SSH connection.

Usage:
    bridge-server --root-dir /path/to/project
    echo '{"id":"1","cmd":"read","args":{"path":"."}}' | bridge-server --root-dir /tmp
"""

import argparse
import json
import subprocess
import sys
import tempfile
from pathlib import Path

MAX_OUTPUT = 1_000_000  # 1MB fallback if client doesn't send max_output


def _resolve(path: str, root: Path) -> Path:
    p = Path(path).expanduser()
    if p.is_absolute():
        return p
    return root / p


def handle_read(args: dict, root: Path) -> dict:
    path = args.get("path", ".")
    offset = args.get("offset", 0)
    limit = args.get("limit", 2000)

    p = _resolve(path, root)
    if not p.is_file():
        raise FileNotFoundError(f"{path} is not a file or does not exist")

    text = p.read_text(errors="replace")

    if args.get("raw"):
        total_lines = len(text.splitlines())
        # Apply offset/limit only when explicitly provided — default is full file.
        if "offset" in args or "limit" in args:
            lines = text.splitlines(keepends=True)
            selected = lines[offset: offset + limit]
            content = "".join(selected)
        else:
            content = text
        return {"content": content, "total_lines": total_lines}

    lines = text.splitlines()
    selected = lines[offset: offset + limit]
    numbered = [f"{i + offset + 1:6}\t{line}" for i, line in enumerate(selected)]
    content = "\n".join(numbered)
    remaining = len(lines) - offset - limit
    if remaining > 0:
        content += f"\n... ({remaining} more lines)"

    return {"content": content or "(empty file)", "total_lines": len(lines)}


def handle_write(args: dict, root: Path) -> dict:
    path = args["path"]
    content = args["content"]

    p = _resolve(path, root)
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(content)

    return {"bytes_written": len(content), "path": str(p)}


def handle_bash(args: dict, root: Path) -> dict:
    command = args["command"]
    timeout = args.get("timeout", 120)
    max_output = args.get("max_output", MAX_OUTPUT)
    cwd = str(_resolve(args["cwd"], root)) if "cwd" in args else str(root)

    with tempfile.TemporaryFile() as tmp_out, tempfile.TemporaryFile() as tmp_err:
        try:
            proc = subprocess.run(
                command,
                shell=True,
                cwd=cwd,
                stdout=tmp_out,
                stderr=tmp_err,
                timeout=timeout,
            )
            exit_code = proc.returncode
        except subprocess.TimeoutExpired:
            exit_code = -1

        tmp_out.seek(0)
        tmp_err.seek(0)
        stdout = tmp_out.read().decode(errors="replace")
        stderr = tmp_err.read().decode(errors="replace")

    if exit_code == -1 and not stderr:
        stderr = f"command timed out after {timeout}s"

    if len(stdout) > max_output:
        stdout = stdout[:max_output] + f"\n[output truncated at {max_output} bytes]"
    if len(stderr) > max_output:
        stderr = stderr[:max_output] + f"\n[output truncated at {max_output} bytes]"

    return {"stdout": stdout, "stderr": stderr, "exit_code": exit_code}


def dispatch(request: dict, root: Path) -> dict:
    req_id = request.get("id", "?")
    cmd = request.get("cmd")
    args = request.get("args", {})

    try:
        if cmd == "read":
            data = handle_read(args, root)
        elif cmd == "write":
            data = handle_write(args, root)
        elif cmd == "bash":
            data = handle_bash(args, root)
        else:
            return {"id": req_id, "ok": False, "error": f"Unknown command: {cmd}"}

        return {"id": req_id, "ok": True, "data": data}

    except Exception as e:
        return {"id": req_id, "ok": False, "error": str(e)}


def main():
    parser = argparse.ArgumentParser(description="cc-bridge server")
    parser.add_argument("--root-dir", required=True, help="Base directory for file operations")
    args = parser.parse_args()

    root = Path(args.root_dir).expanduser().resolve()
    if not root.is_dir():
        print(f"Error: {args.root_dir} is not a directory", file=sys.stderr)
        sys.exit(1)

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            request = json.loads(line)
        except json.JSONDecodeError as e:
            response = {"id": "?", "ok": False, "error": f"Invalid JSON: {e}"}
        else:
            response = dispatch(request, root)

        sys.stdout.write(json.dumps(response) + "\n")
        sys.stdout.flush()


if __name__ == "__main__":
    main()
